background:#121212;
color:white;
}

/* ===============================
 
================================*/
.header{
background:#000;
padding:15px;
text-align:center;
color:#DBB42C;
box-shadow:0 0 10px #DBB42C;
}

/* ===============================
   CONTENEDOR GENERAL
================================*/
.container{
display:flex;
height:90vh;
}

/* ===============================
   MENU LATERAL
================================*/
.sidebar{
width:220px;
background:#0D0D0D;
padding:20px;
}

/* enlaces menú */
.sidebar a{
display:block;
color:#DBB42C;
text-decoration:none;
padding:10px;
margin-bottom:10px;
border-radius:6px;
transition:.3s;
font-weight:bold;
}

/* animación hover */
.sidebar a:hover{
background:#DBB42C;
color:black;
}

/* botón cerrar sesión */
.logout{
margin-top:40px;
background:#DBB42C;
color:black !important;
text-align:center;
}

/* ===============================
   CONTENIDO
================================*/
.content{
flex:1;
background:#242424;
padding:25px;
text-align:center;
}

/* imágenes */
.content img{
width:300px;
height:200px;
margin:10px;
border-radius:10px;
box-shadow:0 0 15px rgba(219,180,44,.4);
transition:.3s;
}

/* animación imagen */
.content img:hover{
transform:scale(1.05);
}

</style>
